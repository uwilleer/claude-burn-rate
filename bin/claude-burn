#!/bin/sh
# claude-burn — minimalist block-usage indicator for Claude Code.
#
# Shows projected usage of your current 5-hour block as a percentage of your
# calibrated block ceiling. Designed to be invoked from Claude Code's
# statusLine hook.
#
# Dependencies: ccusage (https://github.com/ryoppippi/ccusage), jq.

set -eu

VERSION="0.7.4"

usage() {
  cat <<EOF
claude-burn v${VERSION} — Claude Code burn-rate indicator

USAGE:
  claude-burn                           print a single statusline-ready line
  claude-burn calibrate <P> <T>         calibrate from Claude's UI — P is the
                                        "used" percent of the current session,
                                        T is the remaining time (e.g. "1h26m",
                                        "86m", "86"). Both are shown in
                                        Claude settings → Usage.
  claude-burn calibrate-weekly <P> [D]  calibrate weekly limit — P is the
                                        "used" percent of the weekly cap shown
                                        in Claude settings → Usage. D is the
                                        week-start date (YYYY-MM-DD); defaults
                                        to the most recent Monday.
  claude-burn --version                 print version
  claude-burn --help                    show this help

OUTPUT:
  X% → Y%  [W:A%→B%]

  X%  — tokens used so far in the current 5-hour block (% of calibrated ceiling)
  Y%  — projected % by end of block if current pace continues
  A%  — tokens used so far this week (% of calibrated weekly limit)
  B%  — projected % by end of week at current pace (only shown after calibrate-weekly)

INDICATORS (apply to both block and weekly projections):
  (dim grey)  — projection < 60%   (quiet, plenty of headroom)
  🟢          — 60–90%             (normal)
  🟡          — 90–110%            (close to ceiling)
  🔥          — > 110%             (will exceed limit)

ENVIRONMENT:
  BURN_CACHE_DIR       where cache + history + limit files live
                       (default: \$HOME/.claude)
  BURN_MAX_AGE         block cache TTL seconds (default: 15)
  BURN_WEEKLY_MAX_AGE  weekly cache TTL seconds (default: 60)
  BURN_BLOCK_LIMIT     explicit block limit in tokens. Overrides both the
                       calibrated file and ccusage's --token-limit max.
                       Set this if you know your plan's exact per-block
                       token ceiling.
  BURN_GREEN_MAX       upper bound for green (default: 60)
  BURN_YELLOW_MAX      upper bound for yellow (default: 90)
  BURN_RED_MAX         upper bound for red (default: 110)

FILES:
  \$BURN_CACHE_DIR/burn-cache.json         cached block ccusage output
  \$BURN_CACHE_DIR/burn-history            last ≤100 projection samples
  \$BURN_CACHE_DIR/burn-limit              calibrated block token limit
  \$BURN_CACHE_DIR/burn-weekly-cache.json  cached all-blocks ccusage output
  \$BURN_CACHE_DIR/burn-weekly             calibrated weekly token limit

CALIBRATION:
  ccusage by itself does not know your Claude Max plan's real block
  ceiling — it approximates with the historical maximum of your past
  blocks, which may be higher or lower than the real limit. To align
  with what Claude's UI shows:

    1. Open Claude settings → Usage. Note the "Current session" % used
       and the remaining time.
    2. Run: claude-burn calibrate <percent> <remaining-time>

  This writes the block token ceiling and a time offset to
  \$BURN_CACHE_DIR/burn-limit. Without the time offset, projections
  silently inflate because ccusage's idea of "how long is left in the
  block" can be off by 1–2 hours. Re-run calibration whenever the
  indicator and Claude UI drift apart.

WEEKLY CALIBRATION:
  To track weekly pace against the Claude Max weekly cap:

    1. Open Claude settings → Usage. Note your weekly % used.
    2. Run: claude-burn calibrate-weekly <percent> [YYYY-MM-DD]

  The optional date is the Monday (or reset day) that started the current
  week. Defaults to the most recent Monday. After calibration, the
  statusline shows W:A%→B% — current weekly usage and projected
  end-of-week usage. The week advances automatically every 7 days.

  NOTE: ccusage only sees CLI usage. Webapp/mobile/Design usage is not
  logged locally, so weekly totals may be lower than Claude's UI shows.
  Re-calibrate whenever the indicator and Claude UI drift apart.

INTEGRATION:
  Add to ~/.claude/settings.json:
    "statusLine": { "type": "command", "command": "claude-burn" }

  Or append to an existing statusline script — this tool prints exactly one line.
EOF
}

CACHE_DIR="${BURN_CACHE_DIR:-$HOME/.claude}"
CACHE="$CACHE_DIR/burn-cache.json"
HIST="$CACHE_DIR/burn-history"
LIMIT_FILE="$CACHE_DIR/burn-limit"
WEEKLY_CACHE="$CACHE_DIR/burn-weekly-cache.json"
WEEKLY_LIMIT_FILE="$CACHE_DIR/burn-weekly"
MAX_AGE="${BURN_MAX_AGE:-15}"
WEEKLY_MAX_AGE="${BURN_WEEKLY_MAX_AGE:-60}"
GREEN_MAX="${BURN_GREEN_MAX:-60}"
YELLOW_MAX="${BURN_YELLOW_MAX:-90}"
RED_MAX="${BURN_RED_MAX:-110}"

parse_duration() {
  s="$1"
  case "$s" in
    *h*m*) h=${s%%h*}; rest=${s#*h}; m=${rest%m*}; echo $((h * 60 + m)) ;;
    *h)    h=${s%h};                                 echo $((h * 60)) ;;
    *m)    m=${s%m};                                 echo "$m" ;;
    *[!0-9]*) echo "" ;;
    *)     echo "$s" ;;
  esac
}

calibrate() {
  pct="$1"
  rem_input="$2"
  case "$pct" in ''|*[!0-9.]*) echo "claude-burn: calibrate: expected numeric percent, got '$pct'" >&2; exit 2 ;; esac
  real_rem=$(parse_duration "$rem_input")
  case "$real_rem" in ''|*[!0-9]*) echo "claude-burn: calibrate: unrecognised duration '$rem_input' — use e.g. '1h26m', '86m', '86'" >&2; exit 2 ;; esac

  command -v ccusage >/dev/null 2>&1 || { echo "claude-burn: ccusage not found" >&2; exit 1; }
  command -v jq >/dev/null 2>&1 || { echo "claude-burn: jq not found" >&2; exit 1; }

  mkdir -p "$CACHE_DIR"
  cc=$(ccusage blocks --json --active --offline 2>/dev/null)
  total=$(printf '%s' "$cc" | jq -r '.blocks[0].totalTokens // 0')
  cc_rem=$(printf '%s' "$cc" | jq -r '.blocks[0].projection.remainingMinutes // 0')
  cc_rem_int=${cc_rem%.*}

  if [ -z "$total" ] || [ "$total" = "0" ] || [ "$total" = "null" ]; then
    echo "claude-burn: no active block found — start a session first, then re-run calibrate" >&2
    exit 1
  fi

  limit=$(awk -v t="$total" -v p="$pct" 'BEGIN { printf "%d", t / (p / 100) }')
  offset=$((cc_rem_int - real_rem))

  {
    printf 'LIMIT=%s\n' "$limit"
    printf 'OFFSET_MIN=%s\n' "$offset"
  } > "$LIMIT_FILE"

  echo "Calibrated:"
  echo "  tokens used: $total = ${pct}%  → limit ${limit}"
  echo "  ccusage says ${cc_rem_int}m remain; Claude UI says ${real_rem}m → offset ${offset}m"
  echo "  saved to ${LIMIT_FILE}"
}

calibrate_weekly() {
  pct="$1"
  week_start_input="${2:-}"
  case "$pct" in ''|*[!0-9.]*) echo "claude-burn: calibrate-weekly: expected numeric percent, got '$pct'" >&2; exit 2 ;; esac

  if [ -z "$week_start_input" ]; then
    dow=$(date +%u)  # 1=Mon…7=Sun (ISO)
    days_back=$(( dow - 1 ))
    week_start_input=$(date -v-${days_back}d +%Y-%m-%d 2>/dev/null \
      || date -d "${days_back} days ago" +%Y-%m-%d 2>/dev/null \
      || { echo "claude-burn: calibrate-weekly: cannot compute week start — pass YYYY-MM-DD explicitly" >&2; exit 1; })
  fi
  case "$week_start_input" in
    [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]) : ;;
    *) echo "claude-burn: calibrate-weekly: date must be YYYY-MM-DD, got '$week_start_input'" >&2; exit 2 ;;
  esac

  command -v ccusage >/dev/null 2>&1 || { echo "claude-burn: ccusage not found" >&2; exit 1; }
  command -v jq >/dev/null 2>&1 || { echo "claude-burn: jq not found" >&2; exit 1; }

  mkdir -p "$CACHE_DIR"
  raw=$(ccusage blocks --json --offline 2>/dev/null)
  weekly_tokens=$(printf '%s' "$raw" | jq -r \
    --arg since "${week_start_input}T00:00:00.000Z" \
    '[.blocks[] | select(.startTime >= $since) | .totalTokens] | add // 0')

  case "$weekly_tokens" in 0|null|"")
    echo "claude-burn: calibrate-weekly: no blocks found since $week_start_input — check the date" >&2
    exit 1 ;;
  esac

  weekly_limit=$(awk -v t="$weekly_tokens" -v p="$pct" 'BEGIN { printf "%d", t / (p / 100) }')

  {
    printf 'WEEKLY_LIMIT=%s\n' "$weekly_limit"
    printf 'WEEK_START=%s\n' "$week_start_input"
  } > "$WEEKLY_LIMIT_FILE"

  echo "Weekly calibrated:"
  echo "  tokens this week: $weekly_tokens = ${pct}%  → weekly limit ${weekly_limit}"
  echo "  week start: $week_start_input"
  echo "  saved to ${WEEKLY_LIMIT_FILE}"
}

case "${1:-}" in
  -h|--help) usage; exit 0 ;;
  -v|--version) echo "$VERSION"; exit 0 ;;
  calibrate) shift; [ $# -eq 2 ] || { echo "usage: claude-burn calibrate <percent> <remaining-time>" >&2; exit 2; }; calibrate "$1" "$2"; exit 0 ;;
  calibrate-weekly) shift; [ $# -ge 1 ] || { echo "usage: claude-burn calibrate-weekly <percent> [YYYY-MM-DD]" >&2; exit 2; }; calibrate_weekly "$1" "${2:-}"; exit 0 ;;
esac

for dep in ccusage jq; do
  command -v "$dep" >/dev/null 2>&1 || {
    echo "claude-burn: missing dependency: $dep" >&2
    exit 1
  }
done

mkdir -p "$CACHE_DIR"

# Resolve effective block limit + reset-time offset from calibration.
# Env vars take precedence over the calibrated file.
override_limit=""
offset_min=0
if [ -f "$LIMIT_FILE" ]; then
  while IFS='=' read -r k v; do
    case "$k" in
      LIMIT)      override_limit="$v" ;;
      OFFSET_MIN) offset_min="$v" ;;
      *) [ -z "$override_limit" ] && override_limit=$(printf '%s' "$k" | tr -d '[:space:]') ;;
    esac
  done < "$LIMIT_FILE"
fi
[ -n "${BURN_BLOCK_LIMIT:-}" ] && override_limit="$BURN_BLOCK_LIMIT"

now=$(date +%s)
mtime=0
if [ -f "$CACHE" ]; then
  mtime=$(stat -f %m "$CACHE" 2>/dev/null || stat -c %Y "$CACHE" 2>/dev/null || echo 0)
fi
age=$((now - mtime))

if [ ! -f "$CACHE" ] || [ "$age" -gt "$MAX_AGE" ]; then
  if [ -d "$CACHE.lock" ]; then
    lock_mtime=$(stat -f %m "$CACHE.lock" 2>/dev/null || stat -c %Y "$CACHE.lock" 2>/dev/null || echo 0)
    [ $((now - lock_mtime)) -gt 60 ] && rmdir "$CACHE.lock" 2>/dev/null
  fi
  if mkdir "$CACHE.lock" 2>/dev/null; then
    (ccusage blocks --json --active --offline --token-limit max > "$CACHE.tmp" 2>/dev/null \
      && mv "$CACHE.tmp" "$CACHE"; rmdir "$CACHE.lock") >/dev/null 2>&1 &
  fi
fi

[ ! -f "$CACHE" ] && exit 0

parsed=$(jq -r --arg override "$override_limit" --argjson offset "${offset_min:-0}" '
  .blocks[0] as $b
  | ($b.totalTokens // 0) as $total
  | ($b.projection.remainingMinutes // 0) as $cc_rem
  | (if ($override | length) > 0 and ($override | tonumber) > 0
       then ($override | tonumber)
       else ($b.tokenLimitStatus.limit // 1)
     end) as $limit
  | (if ($cc_rem - $offset) < 0 then 0 else ($cc_rem - $offset) end) as $real_rem
  | (if $real_rem > 300 then 300 else $real_rem end) as $rem_clamp
  | (300 - $rem_clamp) as $elapsed
  | (if $elapsed < 30 then 30 else $elapsed end) as $eff_elapsed
  | ($total / $eff_elapsed) as $smooth_rate
  | ($total + $smooth_rate * $rem_clamp) as $proj_total
  | [
      ($total * 100 / $limit),
      ($proj_total * 100 / $limit),
      $real_rem
    ] | @tsv
' "$CACHE" 2>/dev/null) || exit 0

[ -z "$parsed" ] && exit 0

IFS='	' read -r pct_current pct_proj rem_min <<EOF
$parsed
EOF

pct_cur_int=$(printf "%.0f" "$pct_current")
pct_proj_int=$(printf "%.0f" "$pct_proj")

touch "$HIST"
prev_pct=$(awk 'END {print $2}' "$HIST" 2>/dev/null || echo "")
printf '%s %s\n' "$now" "$pct_proj_int" >> "$HIST"

hist_lines=$(wc -l < "$HIST" 2>/dev/null | tr -d ' ')
if [ -n "$hist_lines" ] && [ "$hist_lines" -gt 100 ]; then
  tail -n 100 "$HIST" > "$HIST.tmp" && mv "$HIST.tmp" "$HIST"
fi

if   [ "$pct_proj_int" -lt "$GREEN_MAX" ];  then block_col="\033[2;37m"
elif [ "$pct_proj_int" -lt "$YELLOW_MAX" ]; then block_col="\033[0;32m"
elif [ "$pct_proj_int" -lt "$RED_MAX" ];    then block_col="\033[0;33m"
else                                              block_col="\033[1;31m"
fi

# --- Weekly parsing (only if calibrated; sets wc_int + wp_int) ---
wc_int=""
wp_int=""
if [ -f "$WEEKLY_LIMIT_FILE" ]; then
  w_limit=""
  w_start=""
  while IFS='=' read -r k v; do
    case "$k" in
      WEEKLY_LIMIT) w_limit="$v" ;;
      WEEK_START)   w_start="$v" ;;
    esac
  done < "$WEEKLY_LIMIT_FILE"

  if [ -n "$w_limit" ] && [ -n "$w_start" ]; then
    # Convert week start date to epoch (macOS / Linux)
    w_epoch=$(date -j -f "%Y-%m-%d" "$w_start" "+%s" 2>/dev/null \
      || date -d "$w_start" "+%s" 2>/dev/null || echo "")

    if [ -n "$w_epoch" ]; then
      # Auto-advance week start by 7-day increments (in memory only)
      w_age=$((now - w_epoch))
      while [ "$w_age" -gt "$((7 * 86400))" ]; do
        w_epoch=$((w_epoch + 7 * 86400))
        w_age=$((now - w_epoch))
      done
      w_start=$(date -r "$w_epoch" "+%Y-%m-%d" 2>/dev/null \
        || date -d "@$w_epoch" "+%Y-%m-%d" 2>/dev/null || echo "$w_start")

      # Refresh weekly cache (background, same pattern as block cache)
      mtime_w=0
      [ -f "$WEEKLY_CACHE" ] && \
        mtime_w=$(stat -f %m "$WEEKLY_CACHE" 2>/dev/null || stat -c %Y "$WEEKLY_CACHE" 2>/dev/null || echo 0)
      age_w=$((now - mtime_w))
      if [ ! -f "$WEEKLY_CACHE" ] || [ "$age_w" -gt "$WEEKLY_MAX_AGE" ]; then
        if [ -d "$WEEKLY_CACHE.lock" ]; then
          wlock_mtime=$(stat -f %m "$WEEKLY_CACHE.lock" 2>/dev/null || stat -c %Y "$WEEKLY_CACHE.lock" 2>/dev/null || echo 0)
          [ $((now - wlock_mtime)) -gt 120 ] && rmdir "$WEEKLY_CACHE.lock" 2>/dev/null
        fi
        if mkdir "$WEEKLY_CACHE.lock" 2>/dev/null; then
          (ccusage blocks --json --offline > "$WEEKLY_CACHE.tmp" 2>/dev/null \
            && mv "$WEEKLY_CACHE.tmp" "$WEEKLY_CACHE"; rmdir "$WEEKLY_CACHE.lock") >/dev/null 2>&1 &
        fi
      fi

      if [ -f "$WEEKLY_CACHE" ]; then
        w_parsed=$(jq -r \
          --arg since "${w_start}T00:00:00.000Z" \
          --argjson limit "$w_limit" \
          --argjson now "$now" \
          --argjson ws "$w_epoch" '
          [.blocks[] | select(.startTime >= $since) | .totalTokens] | add // 0 |
          . as $wt |
          if $wt == 0 then empty else
            (($now - $ws) / 86400 | if . < 0.01 then 0.01 else . end) as $days |
            ($wt / $days * 7 / $limit * 100) as $wp |
            ($wt / $limit * 100) as $wc |
            [$wc, $wp] | @tsv
          end
        ' "$WEEKLY_CACHE" 2>/dev/null) || true

        if [ -n "$w_parsed" ]; then
          IFS='	' read -r wc wp <<EOF
$w_parsed
EOF
          wc_int=$(printf "%.0f" "$wc")
          wp_int=$(printf "%.0f" "$wp")
        fi
      fi
    fi
  fi
fi

out=$(printf 'Block: %b%d%% → %d%%\033[0m' "$block_col" "$pct_cur_int" "$pct_proj_int")

if [ -n "$wc_int" ] && [ -n "$wp_int" ]; then
  if   [ "$wp_int" -lt "$GREEN_MAX" ];  then week_col="\033[2;37m"
  elif [ "$wp_int" -lt "$YELLOW_MAX" ]; then week_col="\033[0;32m"
  elif [ "$wp_int" -lt "$RED_MAX" ];    then week_col="\033[0;33m"
  else                                        week_col="\033[1;31m"
  fi
  week_seg=$(printf ' | Week: %b%d%% → %d%%\033[0m' "$week_col" "$wc_int" "$wp_int")
  out="${out}${week_seg}"
fi

# Model recommendation based on tightest projection
max_proj=$pct_proj_int
if [ -n "${wp_int:-}" ] && [ "$wp_int" -gt "$max_proj" ]; then
  max_proj=$wp_int
fi

if   [ "$max_proj" -lt 40 ];  then rec_text='Opus 4.7 (max)'
elif [ "$max_proj" -lt 70 ];  then rec_text='Opus 4.7 (xhigh)'
elif [ "$max_proj" -lt 100 ]; then rec_text='Opus 4.7 (high)'
elif [ "$max_proj" -lt 130 ]; then rec_text='Opus 4.7 (medium)'
elif [ "$max_proj" -lt 180 ]; then rec_text='Sonnet 4.6 (max)'
elif [ "$max_proj" -lt 230 ]; then rec_text='Sonnet 4.6 (high)'
elif [ "$max_proj" -lt 300 ]; then rec_text='Sonnet 4.6 (medium)'
else                               rec_text='Haiku 4.5'
fi

printf '%s\n' "$out"

if [ -n "${BURN_MODEL:-}" ]; then
  cur_text="$BURN_MODEL"
  if [ -n "${BURN_EFFORT:-}" ]; then
    cur_text="$cur_text ($BURN_EFFORT)"
  fi
  printf 'Current: \033[0;35m%s\033[0m | Recommend: %s\n' "$cur_text" "$rec_text"
fi
